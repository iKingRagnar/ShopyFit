# Required: API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: comma-separated list of origins allowed to call this API.
# In production set to your storefront domain (Railway URL or custom domain).
ALLOWED_ORIGINS=http://localhost:8000,https://shopyfit.up.railway.app

# Optional: future Postgres connection (Neon, Railway, Supabase)
# DATABASE_URL=postgresql://user:pass@host:5432/db
